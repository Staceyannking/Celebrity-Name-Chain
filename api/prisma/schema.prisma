// After adding or changing a model, run:  yarn prisma:migrate
// Prisma 7 note: the connection URL lives in `prisma.config.ts`, not here.
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  roomCode      String @id
  celebrityName String

  answers Answer[]
}

model Answer {
  id            Int     @id @default(autoincrement())
  roomCodeID    String
  username      String
  answer        String
  createdAt     DateTime @default(now())

  game          Game     @relation(fields: [roomCodeID], references: [roomCode])

  @@unique([roomCodeID, answer])
}